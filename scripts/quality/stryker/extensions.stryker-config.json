{
  "$schema": "https://stryker-mutator.io/stryker.schema.json",
  "stryker-config": {
    "solution": "Incursa.OpenAI.Agents.slnx",
    "test-projects": [
      "tests/Incursa.OpenAI.Agents.Tests/Incursa.OpenAI.Agents.Tests.csproj"
    ],
